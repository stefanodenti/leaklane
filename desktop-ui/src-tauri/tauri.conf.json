{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LeakLane",
  "version": "0.1.0-alpha.1",
  "identifier": "com.noeva.leaklane",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "LeakLane",
        "width": 1320,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon-256.png",
      "icons/icon-512.png"
    ],
    "resources": {
      "../../web_app.py": "backend/web_app.py",
      "../../scan_public_repos.py": "backend/scan_public_repos.py",
      "../../web": "backend/web"
    }
  }
}
